# ============================================================
# AttendIQ - .gitignore
# ============================================================

# Python virtual environment
venv/
env/
.env/
.venv/

# Python cache files
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package lock (optional to ignore)
package-lock.json

# Environment / secrets
.env
*.env

# OS files
.DS_Store
Thumbs.db

# VS Code settings
.vscode/

# Flask / Python temp
instance/
*.sqlite3
*.db

# Logs
*.log
